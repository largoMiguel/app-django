# Entorno demo — development branch → https://demo.softone360.com
# Copiar a /opt/softone-demo/.env en el servidor.
ENV=demo
DEBUG=false

# Django
SECRET_KEY=replace-with-openssl-rand-hex-64
ALLOWED_HOSTS=demo.softone360.com,files-demo.softone360.com,localhost,127.0.0.1,192.168.1.2
CORS_ALLOWED_ORIGINS=https://demo.softone360.com,http://192.168.1.2:8081
ALLOW_API_DOCS=true
ENABLE_DJANGO_ADMIN=false

# PostgreSQL (base de datos separada de producción)
POSTGRES_DB=softone_demo
POSTGRES_USER=softone_demo
POSTGRES_PASSWORD=replace-with-strong-password

# Admin inicial demo
INITIAL_ADMIN_EMAIL=admin-demo@softone360.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-password
INITIAL_ADMIN_NAME="Admin Demo"

# Clerk — instancia development (pk_test_ / sk_test_)
# Dashboard: añadir http://localhost:5173 y https://demo.softone360.com
# Webhook: https://demo.softone360.com/api/v1/webhooks/clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173,https://demo.softone360.com
# Opcional: crear endpoint en Clerk Dashboard → https://demo.softone360.com/api/v1/webhooks/clerk
CLERK_WEBHOOK_SIGNING_SECRET=
# Opcional: PEM de la instancia development (JWKS de *.clerk.accounts.dev). Si está vacío, Clerk SDK valida online.
CLERK_JWT_KEY=

# Frontend build (Vite)
VITE_FILE_DELIVERY_HOST=files-demo.softone360.com

# OpenAI (opcional en demo — dejar vacío si no se prueba IA)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PDM_CHAT_OPENAI_API_KEY=
PQRS_REPORTS_OPENAI_API_KEY=

# Email deshabilitado en demo por defecto
PQRS_EMAIL_ENABLED=false
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM_EMAIL=noreply@softone360.com
ZEPTOMAIL_WEBHOOK_SECRET=

# PQRS IMAP deshabilitado en demo
PQRS_INBOUND_ENABLED=false

# Acceso HTTP en LAN (distinto al puerto prod 8080)
LAN_HTTP_PORT=8081

# Backblaze B2 — mismo key pair que prod; bucket único demo
USE_B2_STORAGE=true
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_PQRS=storage-demo
B2_BUCKET_PDM=storage-demo
B2_BUCKET_ASISTENCIA=storage-demo
B2_BUCKET_CORRESPONDENCIA=storage-demo
B2_BUCKET_DB=storage-demo

# Entrega firmada vía Worker demo (signing key distinta a prod)
FILE_DELIVERY_BASE_URL=https://files-demo.softone360.com
FILE_DELIVERY_SIGNING_KEY=
FILE_DELIVERY_TTL=600

# Cloudflare API (deploy Worker demo)
# CLOUDFLARE_API_TOKEN=
