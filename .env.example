# Entorno
ENV=prod
DEBUG=false

# Django
SECRET_KEY=replace-with-openssl-rand-hex-64
ALLOWED_HOSTS=app.softone360.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://app.softone360.com
ALLOW_API_DOCS=false
ENABLE_DJANGO_ADMIN=false

# PostgreSQL
POSTGRES_DB=softone
POSTGRES_USER=softone
POSTGRES_PASSWORD=replace-with-strong-password

# Admin inicial (sólo se aplica si la tabla users está vacía)
INITIAL_ADMIN_EMAIL=admin@softone360.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-password
INITIAL_ADMIN_NAME="Admin SoftOne"

# OpenAI — IA para creación automática de PQRS
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email — notificaciones al responder PQRS (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@softone360.com

# Cloudflare Tunnel — credenciales JSON en el servidor (modo config-file)
# CLOUDFLARED_CREDS_DIR=/home/softone/.cloudflared

# Gunicorn (opcional — auto-detecta CPUs si se dejan vacíos)
# GUNICORN_WORKERS=8
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120
