# Entorno
ENV=prod
DEBUG=false

# Django
SECRET_KEY=replace-with-openssl-rand-hex-64
ALLOWED_HOSTS=app.softone360.com,localhost,127.0.0.1,192.168.1.2
CORS_ALLOWED_ORIGINS=https://app.softone360.com,http://192.168.1.2:8080
ALLOW_API_DOCS=false
ENABLE_DJANGO_ADMIN=false

# PostgreSQL
POSTGRES_DB=softone
POSTGRES_USER=softone
POSTGRES_PASSWORD=replace-with-strong-password

# Admin inicial (bootstrap_app vincula también en Clerk si CLERK_SECRET_KEY está definida)
INITIAL_ADMIN_EMAIL=contactenos@softone360.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-password
INITIAL_ADMIN_NAME="Admin SoftOne"

# Clerk — autenticación (producción: pk_live_ / sk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_KEY
CLERK_PUBLISHABLE_KEY=pk_live_YOUR_KEY
CLERK_SECRET_KEY=sk_live_YOUR_KEY
CLERK_AUTHORIZED_PARTIES=https://app.softone360.com
# Opcional: verificación local sin red (JWT public key del dashboard Clerk)
# CLERK_JWT_KEY=
# Webhook: crear endpoint https://app.softone360.com/api/v1/webhooks/clerk en dashboard Clerk
CLERK_WEBHOOK_SIGNING_SECRET=whsec_YOUR_SECRET

# OpenAI — IA para creación automática de PQRS (solo PQRS)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI — Chat IA público del PDM (API key separada de PQRS)
PDM_CHAT_OPENAI_API_KEY=
# PDM_CHAT_MODEL=gpt-4o-mini   # opcional; por defecto usa OPENAI_MODEL

# Email — notificaciones al responder PQRS (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@softone360.com

# Cloudflare Tunnel — credenciales JSON en el servidor (modo config-file)
# CLOUDFLARED_CREDS_DIR=/home/softone/.cloudflared

# Redis (producción Docker: redis://redis:6379/0 — lo inyecta compose)
# REDIS_URL=redis://redis:6379/0

# Acceso HTTP en LAN (nginx en el host; Cloudflare sigue en :443)
# LAN_HTTP_PORT=8080

# Gunicorn (opcional — por defecto min(CPU*2+1, 8) workers × 4 threads)
# GUNICORN_WORKERS=8
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120
