# Entorno
ENV=prod
DEBUG=false

# Django
SECRET_KEY=replace-with-openssl-rand-hex-64
ALLOWED_HOSTS=app.softone360.com,files.softone360.com,localhost,127.0.0.1,192.168.1.2
CORS_ALLOWED_ORIGINS=https://app.softone360.com,http://192.168.1.2:8080
ALLOW_API_DOCS=false
ENABLE_DJANGO_ADMIN=false

# PostgreSQL
POSTGRES_DB=softone
POSTGRES_USER=softone
POSTGRES_PASSWORD=replace-with-strong-password

# Admin inicial (bootstrap_app vincula también en Clerk si CLERK_SECRET_KEY está definida)
INITIAL_ADMIN_EMAIL=contactenos@softone360.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-password
INITIAL_ADMIN_NAME="Admin SoftOne"

# Clerk — autenticación
# Vite (frontend): VITE_CLERK_PUBLISHABLE_KEY  |  Next.js equivalente: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# Test: pk_test_… / sk_test_…  |  Producción: pk_live_… / sk_live_…
# Local: añade http://localhost:5173 en Clerk Dashboard → Configure → Paths / Domains
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY
# Solo producción con dominio custom Clerk:
# VITE_CLERK_DOMAIN=clerk.softone360.com
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY
CLERK_SECRET_KEY=sk_test_YOUR_KEY
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173,https://app.softone360.com
# Opcional: verificación local sin red (JWT public key del dashboard Clerk)
# CLERK_JWT_KEY=
# Webhook: crear endpoint https://app.softone360.com/api/v1/webhooks/clerk en dashboard Clerk
CLERK_WEBHOOK_SIGNING_SECRET=whsec_YOUR_SECRET

# OpenAI — IA para creación automática de PQRS (solo PQRS)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OpenAI — Chat IA público del PDM (API key separada de PQRS)
PDM_CHAT_OPENAI_API_KEY=
# PDM_CHAT_MODEL=gpt-4o-mini   # opcional; por defecto usa OPENAI_MODEL

# Informes PQRS PDF (narrativa IA del reporte institucional)
PQRS_REPORTS_OPENAI_API_KEY=
# PQRS_REPORTS_OPENAI_MODEL=gpt-4o-mini   # opcional; por defecto usa OPENAI_MODEL

# Email — SMTP legacy (otros módulos; PQRS usa ZeptoMail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@softone360.com

# ZeptoMail — correos PQRS (radicación portal + respuesta)
PQRS_EMAIL_ENABLED=true
ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_TOKEN=Zoho-enczapikey YOUR_SEND_MAIL_TOKEN
ZEPTOMAIL_FROM_EMAIL=noreply@softone360.com
# Clave de autenticación del webhook (panel ZeptoMail → Agent → Webhooks → Authentication Key)
ZEPTOMAIL_WEBHOOK_SECRET=

# PQRS — ingreso automático por correo reenviado (IMAP Gmail)
PQRS_INBOUND_ENABLED=false
PQRS_INBOUND_REQUIRE_GOVCO=true
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=pqrssoftone@gmail.com
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX

# Cloudflare Tunnel — credenciales JSON en el servidor (modo config-file)
# CLOUDFLARED_CREDS_DIR=/home/softone/.cloudflared

# Redis (producción Docker: redis://redis:6379/0 — lo inyecta compose)
# REDIS_URL=redis://redis:6379/0

# Acceso HTTP en LAN (nginx en el host; Cloudflare sigue en :443)
# LAN_HTTP_PORT=8080

# Gunicorn (opcional — por defecto min(CPU*2+1, 8) workers × 4 threads)
# GUNICORN_WORKERS=8
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120

# Backblaze B2 — almacenamiento de archivos PQRS/PDM + backups DB
USE_B2_STORAGE=true
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_PQRS=softone-pqrs
B2_BUCKET_PDM=softone-pdm
B2_BUCKET_DB=softone-db

# Entrega vía Cloudflare Worker (Bandwidth Alliance — egress gratis)
FILE_DELIVERY_BASE_URL=https://files.softone360.com
FILE_DELIVERY_SIGNING_KEY=
FILE_DELIVERY_TTL=600

# Cloudflare API token (solo para deploy del Worker files.softone360.com)
# CLOUDFLARE_API_TOKEN=
